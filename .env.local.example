# Supabase — anonymous product analytics (EU-hosted project recommended)
# Copy to .env.local and replace with your project credentials.
# Restart `npm run dev` after changing these values.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Use Project Settings → API in Supabase:
# - URL: Project URL
# - Key: anon public (JWT) or publishable key (sb_publishable_...)

# Production site URL for Open Graph and social preview metadata
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com
